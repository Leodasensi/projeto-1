# ============================================
# CONFIGURACOES DO BOT DE PROMOCOES SHOPEE
# ============================================
# Copie este arquivo para .env e preencha os dados

# ID de Afiliado da Shopee
SHOPEE_AFFILIATE_ID=

# Token de afiliado (opcional - para gerar links automaticamente)
SHOPEE_AFFILIATE_TOKEN=

# Intervalo de atualizacao em segundos (45 min = 2700)
UPDATE_INTERVAL=2700

# Maximo de paginas por busca
MAX_PAGES=3

# Delay entre requisitions em segundos (anti-ban)
REQUEST_DELAY=8

# Modo verbose (true/false)
VERBOSE=true

# País (br para Brasil)
COUNTRY=br
